+      <main className="flex-1 flex min-h-0">
+        {graphData ? (
+          <>
+            {/* Sidebar Explorer */}
+            <div className="w-64 border-r border-border-subtle bg-[#0d0d14] flex flex-col shrink-0 z-10 shadow-[4px_0_24px_rgba(0,0,0,0.2)]">
